// BIDit data model — Chunk 1.
//
// Enum member names MUST stay identical to packages/shared/src/enums.ts.
// test/enums.drift.test.ts fails the build if they drift.
//
// All money is BigInt micro-units (USDC, 6 decimals). Account holds NO balance
// column — balance is always derived from append-only LedgerEntry rows.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  buyer
  seller
  admin
}

enum AccountKind {
  USER
  PLATFORM
  EXTERNAL
  ESCROW
}

enum LedgerType {
  DEPOSIT
  WITHDRAWAL
  BID_HOLD
  BID_HOLD_RELEASE
  PURCHASE_DEBIT
  PAYOUT_CREDIT
  PLATFORM_FEE
  REFUND
  ESCROW_LOCK
  ESCROW_RELEASE
}

enum LedgerRefType {
  DEPOSIT
  WITHDRAWAL
  ORDER
  AUCTION
  BID
  ADJUSTMENT
  TRANSFER
  EXTERNAL
}

enum ListingStatus {
  DRAFT
  QUEUED
  LIVE
  SOLD
  UNSOLD
  CANCELED
}

enum AuctionStatus {
  PENDING
  RUNNING
  SETTLING
  CLOSED
  CANCELED
}

enum BidStatus {
  ACTIVE
  OUTBID
  WON
  LOST
  VOID
}

enum OrderStatus {
  PENDING_SETTLEMENT
  LOCKED
  SHIPPED
  DELIVERED
  DISPUTE_WINDOW
  DISPUTED
  RELEASED
  REFUNDED
  CANCELED
}

enum HoldStatus {
  ACTIVE
  RELEASED
  CAPTURED
}

model User {
  id            String   @id @default(cuid())
  handle        String   @unique
  email         String?  @unique
  passwordHash  String?
  displayName   String?
  avatarUrl     String?
  bio           String?
  shippingAddress Json?
  bundleShipping Boolean @default(false) // opt-in: bundle shipping weekly per seller (where offered)
  // Buyer's preferred shipping option, chosen from the bid panel. Drives the
  // default at ship time. WEEKLY_BUNDLE keeps bundleShipping in sync.
  shippingMode  String  @default("SHIP_LATER") // WEEKLY_BUNDLE | SHIP_LATER | PRIVATE
  interests     String[] @default([])
  onboarded     Boolean  @default(false)
  walletAddress String?  @unique
  role          Role     @default(buyer)
  // BIDit Points — activity rewards redeemed against future community airdrops.
  // Denormalized sum of PointsEvents, kept in step for fast leaderboard reads.
  points        BigInt   @default(0)
  // Sessions (bearer tokens) issued before this instant are revoked — set on
  // logout / password change. null = never revoked. Mirrored in-memory for O(1) auth.
  sessionsValidFrom DateTime?
  createdAt     DateTime @default(now())

  account       Account?
  sellerProfile SellerProfile?
  listings      Listing[]
  bids          Bid[]
  ordersBought  Order[]      @relation("BuyerOrders")
  ordersSold    Order[]      @relation("SellerOrders")
  withdrawals   Withdrawal[]
  pointsEvents  PointsEvent[]
}

model SellerProfile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  user                User     @relation(fields: [userId], references: [id])
  // A seller is active as soon as they apply, but stays UNVERIFIED until they
  // fulfill 10 orders (or an admin verifies them). `verified` is the trust badge,
  // NOT a gate on selling.
  verified            Boolean   @default(false)
  verifiedAt          DateTime?
  verifiedBy          String?   // 'auto' (10 orders) | admin userId
  appliedAt           DateTime?
  onboardedSeller     Boolean   @default(false)
  // Seller application / shop profile.
  website             String?
  socials             Json?     // { x?, instagram?, tiktok?, youtube? }
  pitch               String?   // what they sell, in their words
  pumpCoinAddress     String?
  // Livestream identity shown on the "Live right now" cards. `streamTitle` lets a
  // seller name their stream instead of falling back to the coin name;
  // `streamCategory` drives the small category tag on the card.
  streamTitle         String?
  streamCategory      String?
  payoutWalletAddress String?
  // Ship-from origin (drives weight/zone rate quotes) + which shipping modes the
  // seller offers on their page.
  originCountry       String?
  originRegion        String?
  originCity          String?
  originPostal        String?
  weeklyBundling      Boolean   @default(false)
  shipLater           Boolean   @default(false)
  privateShipping     Boolean   @default(false)
  // Launch "$100 to sell" promo: set once the seller's $100 bonus has been paid
  // out manually (off-platform). Enrollment is derived from createdAt vs the
  // promo window, so no flag is needed for that.
  promoBonusPaidAt    DateTime?
  createdAt           DateTime  @default(now())
}

/// One per user (USER kind), plus two singleton system accounts (PLATFORM,
/// EXTERNAL) with fixed ids and null userId.
model Account {
  id             String      @id @default(cuid())
  kind           AccountKind @default(USER)
  userId         String?     @unique
  user           User?       @relation(fields: [userId], references: [id])
  depositAddress String?     @unique
  createdAt      DateTime    @default(now())

  ledgerEntries LedgerEntry[]
  holds         Hold[]

  @@index([kind])
}

/// On-chain withdrawal record (USDC sent from treasury to a user's address).
///
/// Durable settlement state machine (see withdrawals.ts). The ledger debit is
/// posted once, up front; the row then tracks the on-chain transfer's fate so we
/// only ever reverse the debit when the chain *proves* the transfer is dead —
/// never on an ambiguous send timeout (which could otherwise double-credit a user
/// whose USDC actually left the treasury).
///   PENDING      — created + debited, not yet broadcast.
///   SUBMITTED    — broadcast; signature known; awaiting confirmation.
///   CONFIRMED    — transfer finalized on-chain (terminal).
///   FAILED       — transfer permanently dead; debit reversed exactly once (terminal).
///   NEEDS_REVIEW — fate still indeterminate after a long time (RPC outage); debit
///                  retained (NOT reversed) and surfaced for an operator.
model Withdrawal {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  toAddress String
  amount    BigInt
  status    String   @default("PENDING") // PENDING | SUBMITTED | CONFIRMED | FAILED | NEEDS_REVIEW
  txSig     String?
  /// Solana blockhash expiry height captured at broadcast. Once the chain's block
  /// height passes this and the signature is still not found, the transfer can
  /// never land → safe to reverse. Null for chains without the concept (mock).
  lastValidBlockHeight BigInt?
  /// Set the instant the debit is reversed (credited back). Guards against ever
  /// reversing twice; the ledger reversal is also idempotency-keyed as a backstop.
  reversedAt DateTime?
  /// Last transition reason / error, for operator visibility on stuck rows.
  lastError String?
  createdAt DateTime @default(now())
  // @default(now()) gives the column a DB-level default so `prisma db push` can
  // add it to a table that already has rows on deploy (no --accept-data-loss).
  updatedAt DateTime @updatedAt @default(now())

  @@index([userId])
  @@index([status])
}

/// Durable outbox for the INTERNAL wallet→wallet USDC moves that keep the physical
/// wallets aligned with the ledger's escrow/fee accounting (lock, release×3,
/// refund, shipping→fee). Each row is enqueued ATOMICALLY with its ledger move
/// (same DB transaction, keyed for idempotency), and a ChainSettler drives it to
/// CONFIRMED. Because every wallet here is operator-controlled, a failed/expired
/// send is simply retried with a fresh blockhash — funds never leave our control,
/// so a crash can neither lose money nor double-move it. This is what makes the
/// DB↔chain boundary safe (see chain-settle.ts).
model ChainTransfer {
  id                   String    @id @default(cuid())
  /// One row per logical leg — e.g. `lock:<orderId>`, `release-seller:<orderId>`,
  /// `shipping:<shipmentId>`. Unique, so enqueuing is idempotent.
  key                  String    @unique
  fromWallet           String    // treasury | escrow | buyback | fee
  toWallet             String    // treasury | escrow | buyback | fee (all ours)
  amount               BigInt
  memo                 String?
  status               String    @default("PENDING") // PENDING | SUBMITTED | CONFIRMED
  txSig                String?
  lastValidBlockHeight BigInt?
  attempts             Int       @default(0)
  lastError            String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt @default(now())

  @@index([status])
}

/// Public record of a $BID buyback funded by the 5% platform fee pool.
model Buyback {
  id        String   @id @default(cuid())
  amount    BigInt // USDC micro-units spent buying $BID
  txSig     String?
  status    String   @default("EXECUTED") // EXECUTED | PENDING | FAILED
  createdAt DateTime @default(now())
}

/// Append-only. Never updated, never deleted. The sum of all entries across all
/// accounts is invariantly zero (double-entry).
model LedgerEntry {
  id             String        @id @default(cuid())
  accountId      String
  account        Account       @relation(fields: [accountId], references: [id])
  amount         BigInt // signed micro-units (USDC, 6 decimals)
  type           LedgerType
  refType        LedgerRefType
  refId          String?
  idempotencyKey String?       @unique
  createdAt      DateTime      @default(now())

  @@index([accountId])
  @@index([refType, refId])
}

model Listing {
  id          String        @id @default(cuid())
  sellerId    String
  seller      User          @relation(fields: [sellerId], references: [id])
  title       String
  description String?
  photos      String[]
  startingBid BigInt
  /** Store "buy now" price (micro-USDC). When set, the listing also appears in
   *  the seller's shop and can be bought outright — no auction needed. */
  buyNowPrice BigInt?
  /** Units the seller has of this item. Each sale decrements it; while > 0 the
   *  listing can be auctioned again. */
  quantity    Int           @default(1)
  weightGrams Int?
  category    String?
  status      ListingStatus @default(DRAFT)
  createdAt   DateTime      @default(now())

  /** Optional wheel-spin prize pool (WheelEntry[]). When set, the auction is a
   *  "bid to win a roll" — on close the server spins to assign the prize. */
  wheel       Json?

  auctions Auction[]
  orders   Order[]

  @@index([sellerId])
  @@index([status])
}

model Auction {
  id                  String        @id @default(cuid())
  listingId           String
  listing             Listing       @relation(fields: [listingId], references: [id])
  status              AuctionStatus @default(PENDING)
  startingBid         BigInt
  currentBid          BigInt?
  currentLeaderUserId String?
  durationSeconds     Int           @default(20)
  counterBidSeconds   Int           @default(10)
  minIncrementBps     Int           @default(500)
  minIncrementFloor   BigInt        @default(1000000)
  endsAt              DateTime?
  createdAt           DateTime      @default(now())

  bids  Bid[]
  holds Hold[]
  order Order?

  @@index([listingId])
  @@index([status])
  @@index([status, endsAt])
}

model Bid {
  id        String    @id @default(cuid())
  auctionId String
  auction   Auction   @relation(fields: [auctionId], references: [id])
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  amount    BigInt
  status    BidStatus @default(ACTIVE)
  createdAt DateTime  @default(now())

  hold Hold?

  @@index([auctionId])
  @@index([userId])
}

/// Funds locked because a user is the current high bidder on an auction. At most
/// one ACTIVE hold per auction at a time (the leader's). available_balance =
/// settled_balance - SUM(ACTIVE holds). Authoritative here in Postgres; Redis
/// becomes a real-time cache reconciled against this table in a later chunk.
model Hold {
  id         String     @id @default(cuid())
  accountId  String
  account    Account    @relation(fields: [accountId], references: [id])
  auctionId  String
  auction    Auction    @relation(fields: [auctionId], references: [id])
  bidId      String?    @unique
  bid        Bid?       @relation(fields: [bidId], references: [id])
  amount     BigInt
  status     HoldStatus @default(ACTIVE)
  createdAt  DateTime   @default(now())
  releasedAt DateTime?

  @@index([accountId, status])
  @@index([auctionId, status])
}

model Order {
  id             String      @id @default(cuid())
  /** The auction this order settles — null for store ("buy now") purchases. */
  auctionId      String?     @unique
  auction        Auction?    @relation(fields: [auctionId], references: [id])
  /** Direct listing link for store purchases (auction orders reach the listing
   *  through the auction instead). */
  listingId      String?
  listing        Listing?    @relation(fields: [listingId], references: [id])
  buyerId        String
  buyer          User        @relation("BuyerOrders", fields: [buyerId], references: [id])
  sellerId       String
  seller         User        @relation("SellerOrders", fields: [sellerId], references: [id])
  amount         BigInt
  platformFee    BigInt
  sellerProceeds BigInt
  status         OrderStatus @default(PENDING_SETTLEMENT)
  escrowRef      String?
  trackingNumber String?
  lockedAt           DateTime?
  noShipDeadline     DateTime?
  shippedAt          DateTime?
  deliveredAt        DateTime?
  disputeWindowEndsAt DateTime?
  disputedAt         DateTime?
  // Buyer's dispute: why (reason code), the written detail, and evidence photos.
  disputeReason      String?
  disputeDetail      String?
  disputePhotos      String[]  @default([])
  releasedAt         DateTime?
  refundedAt         DateTime?
  canceledAt         DateTime?
  createdAt          DateTime    @default(now())

  @@index([status])
  @@index([status, disputeWindowEndsAt])
  @@index([status, noShipDeadline])
}

/// A physical card a buyer won and must receive. Created on each direct-payout
/// sale. Snapshots title/photo/weight so the buyer's "Ready to ship" list needs
/// no joins. Grouped into a Shipment for fulfillment. Plain-string status (see
/// Giveaway) to stay out of the shared-enum drift test.
model FulfillmentItem {
  id          String    @id @default(cuid())
  orderId     String    @unique
  buyerId     String
  sellerId    String
  listingId   String
  title       String
  photo       String?
  weightGrams Int?
  amount      BigInt    // item price paid — for display + forfeit accounting
  status      String    @default("READY_TO_SHIP") // READY_TO_SHIP | IN_SHIPMENT | SHIPPED | DELIVERED | DISCARDED
  heldUntil   DateTime? // seller physically holds the item until this (ship-later 7d cap)
  shipmentId  String?
  discardedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([buyerId, status])
  @@index([sellerId, status])
  @@index([shipmentId])
  @@index([status, heldUntil])
}

/// One package: items from ONE seller to ONE buyer, one shipping fee. All four
/// shipping modes (standard / weekly bundle / ship-later / private) are just
/// policies over how items land here and when the fee is charged.
model Shipment {
  id             String    @id @default(cuid())
  buyerId        String
  sellerId       String
  mode           String    @default("STANDARD") // STANDARD | WEEKLY_BUNDLE | SHIP_LATER | PRIVATE
  // Platform-label pipeline: PENDING_PAYMENT -> PAID (buyer paid shipping) ->
  // LABEL_PENDING (seller confirmed package size; BIDit is making the label) ->
  // LABEL_CREATED (label attached; seller can download + ship) -> SHIPPED ->
  // DELIVERED. CANCELED at any point.
  status         String    @default("PENDING_PAYMENT") // PENDING_PAYMENT | PAID | LABEL_PENDING | LABEL_CREATED | SHIPPED | DELIVERED | CANCELED
  shippingFee    BigInt    @default(0)
  privacyFee     BigInt    @default(0)
  shipTo         Json      // address snapshot BIDit puts on the label (operator hub when PRIVATE)
  privateLeg2    Json?     // buyer's real address for the operator's reship leg (PRIVATE only)
  trackingNumber String?
  carrier        String?
  // Package the seller will send (entered at confirm) + the label BIDit generates.
  lengthCm       Int?
  widthCm        Int?
  heightCm       Int?
  packageWeightG Int?
  labelUrl       String?
  paidAt         DateTime?
  confirmedAt    DateTime? // seller confirmed size → label queued for the operator
  labelCreatedAt DateTime? // operator attached the label; seller can download + ship
  shippedAt      DateTime?
  deliveredAt    DateTime?
  canceledAt     DateTime?
  createdAt      DateTime  @default(now())

  @@index([buyerId, status])
  @@index([sellerId, status])
}

/// Weekly bundling: while a buyer has an open pass with a seller, that week's
/// wins ride the same Shipment for free (shipping charged once, at the first win
/// of the week — see decision log). Closed when the seller ships the bundle.
model WeeklyShippingPass {
  id         String    @id @default(cuid())
  buyerId    String
  sellerId   String
  shipmentId String
  weekStart  DateTime  @default(now())
  expiresAt  DateTime
  closedAt   DateTime?
  createdAt  DateTime  @default(now())

  @@index([buyerId, sellerId, closedAt])
}

/// In-app notification (also emailed via Resend for key events). Plain-string
/// kind to stay out of the shared-enum drift test.
model Notification {
  id        String    @id @default(cuid())
  userId    String
  kind      String
  title     String
  body      String?
  href      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt])
  @@index([userId, createdAt])
}

// Giveaways (Whatnot-style). kind/status are plain strings (not enums) to avoid
// coupling to shared/enums.ts via the drift test; values are validated in code.
// The server commits seedHash at open and reveals seed at the draw, so the
// winner is verifiable. No formal User relation — entrant handles are fetched
// by id when the roll is built.
model Giveaway {
  id           String    @id @default(cuid())
  sellerId     String
  kind         String    // PUBLIC | BUYER_ONLY
  prize        String
  image        String?   // optional prize photo (data URL or https)
  status       String    @default("OPEN") // OPEN | DRAWING | CLOSED
  seed         String    // server secret, revealed at draw
  seedHash     String    // sha256(seed), committed at open
  winnerUserId String?
  opensAt      DateTime  @default(now())
  closesAt     DateTime
  drawnAt      DateTime?
  createdAt    DateTime  @default(now())

  entries GiveawayEntry[]

  @@index([sellerId, status])
}

model GiveawayEntry {
  id         String   @id @default(cuid())
  giveawayId String
  giveaway   Giveaway @relation(fields: [giveawayId], references: [id], onDelete: Cascade)
  userId     String
  createdAt  DateTime @default(now())

  @@unique([giveawayId, userId])
  @@index([giveawayId])
}

/// One points grant — the append-only audit trail behind User.points. `kind` is
/// 'buy'/'sell' for automatic accrual (ref = orderId) or 'mission:<id>' for a
/// claimed one-time bonus (ref = ''). The unique key makes every award idempotent.
model PointsEvent {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  kind      String
  ref       String   @default("")
  points    BigInt
  createdAt DateTime @default(now())

  @@unique([userId, kind, ref])
  @@index([userId, createdAt])
}

/// Durable record of a detected on-chain deposit sweep, written BEFORE the ledger
/// credit so a crash between sweeping the funds and crediting the user can never
/// lose the money. The credit is idempotent (idempotencyKey chain-deposit:<txSig>)
/// and `creditedAt` flips once applied; reconcile-on-startup finishes any row that
/// was recorded but not yet credited.
model DepositReceipt {
  id           String    @id @default(cuid())
  userId       String
  amountMicros BigInt
  txSig        String    @unique
  sweptAt      DateTime  @default(now())
  creditedAt   DateTime?

  @@index([creditedAt])
  @@index([userId])
}

/// A live-chat message in a seller's room (roomId = seller's userId). handle is a
/// snapshot so the feed renders without a User join; deletedAt soft-deletes for
/// seller moderation. Lightweight, no relations (matches GiveawayEntry style).
model ChatMessage {
  id        String    @id @default(cuid())
  roomId    String // seller's userId (the room)
  userId    String // sender
  handle    String // sender handle snapshot
  text      String    @db.VarChar(300)
  createdAt DateTime  @default(now())
  deletedAt DateTime?

  @@index([roomId, createdAt])
  @@index([roomId, userId, createdAt]) // per-user cooldown lookup
}

/// A seller blocking a user from their chat room. Presence of a row = blocked.
model ChatBlock {
  id        String   @id @default(cuid())
  roomId    String // seller's userId
  userId    String // blocked user
  createdAt DateTime @default(now())

  @@unique([roomId, userId])
}
